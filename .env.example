# ─── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB Atlas ────────────────────────────────────────────
MONGO_URI=mongodb+srv://youruser:yourpassword@cluster0.xxxxx.mongodb.net/skillbridge?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=skillbridge_jwt_secret_key_2025_make_it_long_random
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=skillbridge_refresh_secret_key_2025_long_random
