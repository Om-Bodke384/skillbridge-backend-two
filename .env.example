# ─── Client ───────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── Email (Brevo) ────────────────────────────────────────────
EMAIL_PROVIDER=brevo
EMAIL_FROM_NAME=SkillBridge
EMAIL_FROM_ADDRESS=ombodke384@gmail.com
BREVO_SMTP_USER=a7297a001@smtp-brevo.com
BREVO_SMTP_KEY=your_brevo_master_password_here

